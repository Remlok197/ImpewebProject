@using ImpewebProject.Models
@using ImpewebProject.Services
@inject ICotizacionService CotizacionService

@if (Mostrar)
{
    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[60] flex items-center justify-center p-4 animate-fade-in">

        <div class="bg-white w-full max-w-5xl max-h-[90vh] rounded-2xl shadow-2xl flex flex-col overflow-hidden animate-zoom-in">

            <div class="px-8 py-6 bg-slate-50 border-b border-slate-200 flex justify-between items-center">
                <div>
                    <h3 class="text-xl font-bold text-slate-900">Detalle de Cotización</h3>
                    <p class="text-sm text-slate-500 font-mono">Folio: @CotizacionId</p>
                </div>
                <button @onclick="CerrarModal" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-200 rounded-full transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="flex-1 overflow-auto p-8">
                @if (cargando)
                {
                    <div class="flex flex-col items-center justify-center py-20">
                        <div class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
                        <p class="mt-4 text-slate-500 font-medium">Cargando detalles...</p>
                    </div>
                }
                else if (detalles == null || !detalles.Any())
                {
                    <div class="text-center py-20 text-slate-500">
                        <span class="material-symbols-outlined text-5xl mb-2 text-slate-300">inventory_2</span>
                        <p>No se encontraron partidas para esta cotización.</p>
                    </div>
                }
                else
                {
                    <div class="border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                        <table class="w-full text-left border-collapse min-w-max">
                            <thead class="bg-slate-800 text-white">
                                <tr>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase">Código</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase">Descripción</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase">Uda</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">Cantidad</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">Precio $</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">Importe $</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">Dcto %</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">Dcto $</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">SubTotal $</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">Iva %</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                @foreach (var d in detalles)
                                {
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="px-4 py-3 text-xs font-bold text-slate-700">@d.Codigo</td>
                                        <td class="px-4 py-3 text-xs text-slate-600 whitespace-pre-wrap">@d.Descripcion</td>
                                        <td class="px-4 py-3 text-xs text-slate-500">@d.Unidad</td>
                                        <td class="px-4 py-3 text-xs text-right text-slate-700">@d.Cantidad?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-right text-slate-700">@d.Precio?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-right text-slate-700">@d.Importe?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-right text-slate-500">@d.Dcto?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-right text-slate-500">@d.Descuento?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-right font-bold text-slate-900">@d.SubTotal?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-right text-slate-500">@d.Iva?.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-8 flex justify-end">
                        <div class="w-full max-w-xs bg-slate-50 border border-slate-200 rounded-xl p-6 space-y-3 shadow-sm">
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-500">Importe:</span>
                                <span class="font-bold text-slate-900">@SumaImporte.ToString("C2")</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-500">Descuento:</span>
                                <span class="font-bold text-red-600">- @SumaDescuento.ToString("C2")</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-500">SubTotal:</span>
                                <span class="font-bold text-slate-900">@SumaSubTotal.ToString("C2")</span>
                            </div>
                            <div class="flex justify-between text-sm">
                                <span class="text-slate-500">IVA:</span>
                                <span class="font-bold text-slate-900">@SumaIva.ToString("C2")</span>
                            </div>
                            <div class="pt-3 border-t border-slate-200 flex justify-between items-center">
                                <span class="text-base font-bold text-slate-900 uppercase">Total:</span>
                                <span class="text-2xl font-black text-blue-600">@SumaTotalFinal.ToString("C2")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="px-8 py-4 bg-slate-50 border-t border-slate-200 flex justify-end">
                <button @onclick="CerrarModal" class="px-6 py-2 bg-slate-800 text-white font-bold rounded-lg hover:bg-slate-900 transition-colors shadow-lg">
                    Cerrar Detalles
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Mostrar { get; set; }
    [Parameter] public string? CotizacionId { get; set; }
    [Parameter] public EventCallback OnCerrar { get; set; }

    private List<VwDetalleCotizacion>? detalles;
    private bool cargando = false;

    private decimal SumaImporte => detalles?.Sum(x => x.Importe ?? 0) ?? 0;
    private decimal SumaDescuento => detalles?.Sum(x => x.Descuento ?? 0) ?? 0;
    private decimal SumaSubTotal => detalles?.Sum(x => x.SubTotal ?? 0) ?? 0;
    private decimal SumaTotalFinal => detalles?.Sum(x => x.Total ?? 0) ?? 0;
    private decimal SumaIva => SumaTotalFinal - SumaSubTotal;

    protected override async Task OnParametersSetAsync()
    {
        if (Mostrar && !string.IsNullOrEmpty(CotizacionId))
        {
            cargando = true;
            detalles = await CotizacionService.ObtenerDetallesPorCotizacionAsync(CotizacionId);
            cargando = false;
        }
    }

    private async Task CerrarModal()
    {
        detalles = null;
        await OnCerrar.InvokeAsync();
    }
}