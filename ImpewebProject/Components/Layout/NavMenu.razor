    </NavLink>

        <NavLink href="/pedidos" Match="NavLinkMatch.All" class="flex items-center gap-3 px-4 py-3 text-slate-400 hover:bg-slate-800/50 hover:text-white rounded-lg transition-all" ActiveClass="bg-blue-600/10 text-blue-400 border-l-4 border-blue-500 font-medium">
            <span class="material-symbols-outlined">orders</span> Ordenes de Compra
        </NavLink>
    
    <NavLink href="/facturas" class="flex items-center gap-3 px-4 py-3 text-slate-400 hover:bg-slate-800/50 hover:text-white rounded-lg transition-all" ActiveClass="bg-blue-600/10 text-blue-400 border-l-4 border-blue-500 font-medium">
      <span class="material-symbols-outlined">description</span> Facturas
    </NavLink>
    
    <NavLink href="/cotizaciones" class="flex items-center gap-3 px-4 py-3 text-slate-400 hover:bg-slate-800/50 hover:text-white rounded-lg transition-all" ActiveClass="bg-blue-600/10 text-blue-400 border-l-4 border-blue-500 font-medium">
      <span class="material-symbols-outlined">request_quote</span> Cotizaciones
