@using ImpewebProject.Models
@using ImpewebProject.Services
@inject IComplementosPagoService ComplementosPagoService

@if (Mostrar)
{
    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[60] flex items-center justify-center p-4 animate-fade-in">

        <div class="bg-white w-full max-w-4xl max-h-[90vh] rounded-2xl shadow-2xl flex flex-col overflow-hidden animate-zoom-in">

            <div class="px-8 py-6 bg-slate-50 border-b border-slate-200 flex justify-between items-center">
                <div>
                    <h3 class="text-xl font-bold text-slate-900">Detalle del Complemento de Pago</h3>
                    <p class="text-sm text-slate-500 font-mono">Pago: @PagoId</p>
                </div>
                <button @onclick="CerrarModal" class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-200 rounded-full transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="flex-1 overflow-auto p-8">
                @if (cargando)
                {
                    <div class="flex flex-col items-center justify-center py-20">
                        <div class="w-12 h-12 border-4 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
                        <p class="mt-4 text-slate-500 font-medium">Cargando facturas pagadas...</p>
                    </div>
                }
                else if (detalles == null || !detalles.Any())
                {
                    <div class="text-center py-20 text-slate-500">
                        <span class="material-symbols-outlined text-5xl mb-2 text-slate-300">receipt_long</span>
                        <p>No se encontraron documentos relacionados a este pago.</p>
                    </div>
                }
                else
                {
                    <div class="border border-slate-200 rounded-xl overflow-hidden shadow-sm">
                        <table class="w-full text-left border-collapse min-w-max">
                            <thead class="bg-slate-800 text-white">
                                <tr>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase">Factura (DR)</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-center">Parcialidad</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">Saldo Anterior $</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right text-green-400">Abono $</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-right">Saldo Insoluto $</th>
                                    <th class="px-4 py-3 text-[10px] font-bold uppercase text-center">ObjetoImpDR</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-slate-100">
                                @foreach (var d in detalles)
                                {
                                    <tr class="hover:bg-slate-50/50 transition-colors">
                                        <td class="px-4 py-3 text-xs font-bold text-slate-700">@d.Factura</td>
                                        <td class="px-4 py-3 text-xs text-center text-slate-600">@d.NumParcialidad</td>
                                        <td class="px-4 py-3 text-xs text-right text-slate-500">@d.ImpSaldoAnt?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-right font-bold text-green-600">@d.ImpPagado?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-right text-red-500 font-medium">@d.ImpSaldoInsoluto?.ToString("N2")</td>
                                        <td class="px-4 py-3 text-xs text-center text-slate-500">@d.ObjetoImpDR</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-8 flex justify-end">
                        <div class="w-full max-w-xs bg-slate-50 border border-slate-200 rounded-xl p-6 shadow-sm">
                            <div class="flex justify-between items-center">
                                <span class="text-base font-bold text-slate-900 uppercase">Suma Abonos:</span>
                                <span class="text-2xl font-black text-green-600">@SumaAbonos.ToString("C2")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="px-8 py-4 bg-slate-50 border-t border-slate-200 flex justify-end">
                <button @onclick="CerrarModal" class="px-6 py-2 bg-slate-800 text-white font-bold rounded-lg hover:bg-slate-900 transition-colors shadow-lg">
                    Cerrar Detalles
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Mostrar { get; set; }
    [Parameter] public string? PagoId { get; set; }
    [Parameter] public EventCallback OnCerrar { get; set; }

    private List<VwDetallePago>? detalles;
    private bool cargando = false;

    private decimal SumaAbonos => detalles?.Sum(x => x.ImpPagado ?? 0) ?? 0;

    protected override async Task OnParametersSetAsync()
    {
        if (Mostrar && !string.IsNullOrEmpty(PagoId))
        {
            cargando = true;
            detalles = await ComplementosPagoService.ObtenerDetallesPorPagoAsync(PagoId);
            cargando = false;
        }
    }

    private async Task CerrarModal()
    {
        detalles = null;
        await OnCerrar.InvokeAsync();
    }
}