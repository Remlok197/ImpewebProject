@rendermode InteractiveServer
@using ImpewebProject.Models
@using ImpewebProject.Services
@using ImpewebProject.Components.Modals
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using System.IO
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider

<!-- FILTROS INICIO -->
<div class="card mb-3">
    <div class="mb-8">
        <h2 class="text-2xl font-bold text-slate-900">Listado de Complementos de Pago</h2>
        <p class="text-slate-500">Consulta y gestiona tus comprobantes fiscales.</p>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-6 mb-8 shadow-sm">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 items-end">
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">Periodo (Año)</label>
                <select class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition-all" @bind="draftAnio">
                    @for (int i = DateTime.Now.Year; i >= 2015; i--)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">RFC</label>
                <input type="text" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition-all disabled:opacity-50"
                       @bind="DraftRfcFiltro" disabled="@(!EsAdmin)" placeholder="Buscar RFC..." />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">Cliente</label>
                <select class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition-all" @bind="filtroCliente">
                    <option value="">Todos los clientes</option>
                    @foreach (var cliente in ClientesDisponibles)
                    {
                        <option value="@cliente.Numero">@cliente.Nombre</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">Desde</label>
                <input type="date" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition-all" @bind="draftFechaInicio" />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">Hasta</label>
                <input type="date" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition-all" @bind="draftFechaFin" />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-400 uppercase mb-2">UUID</label>
                <input type="text" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition-all" @bind="draftUUID" placeholder="Buscar UUID..." />
            </div>
        </div>

        <div class="mt-6 flex gap-3">
            <button @onclick="AplicarFiltros" class="px-6 py-2 bg-blue-600 text-white font-bold rounded-lg hover:bg-blue-700 shadow-lg shadow-blue-600/20 transition-all active:scale-95">
                Buscar
            </button>
            <button @onclick="LimpiarFiltros" class="px-6 py-2 bg-slate-100 text-slate-600 font-bold rounded-lg hover:bg-slate-200 transition-all">
                Limpiar
            </button>
        </div>
    </div>
</div>
<!-- FILTROS FINAL -->

<!-- TABLAS INICIO -->
@if (!busquedaRealizada)
{
    <div class="bg-blue-50 border border-blue-100 rounded-2xl p-8 text-center shadow-sm mb-6 flex flex-col items-center">
        <span class="material-symbols-outlined text-blue-500 text-5xl mb-3">filter_alt</span>
        <p class="text-blue-900"><strong class="font-bold">Seleccione sus filtros y presione "Buscar"</strong> para cargar los pagos.</p>
    </div>
}
else if (!ElementosPaginados.Any())
{
    <div class="bg-amber-50 border border-amber-100 rounded-2xl p-8 text-center shadow-sm mb-6 flex flex-col items-center">
        <span class="material-symbols-outlined text-amber-500 text-5xl mb-3">warning</span>
        <p class="text-amber-900 font-medium">No se encontraron pagos con los filtros seleccionados.</p>
    </div>
}
else
{
    <div class="flex justify-between items-center mb-4 px-1">
        <div class="flex items-center gap-2 text-sm text-slate-600">
            <label class="font-medium">Mostrar</label>
            <select class="px-2 py-1 bg-white border border-slate-200 rounded-md focus:ring-2 focus:ring-blue-500 outline-none transition-all" @bind="RegistrosPorPagina" @bind:event="onchange">
                <option value="10">10</option>
                <option value="25">25</option>
                <option value="50">50</option>
                <option value="100">100</option>
            </select>
            <label>registros</label>
        </div>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm mb-6">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse min-w-max whitespace-nowrap">
                <thead class="bg-slate-800 text-white">
                    <tr>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider">Pago</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider">Folio</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider">Fecha Emisión</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider">Fecha Pago</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider">Cliente</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-right">Abono</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider">Forma de Pago</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider">UUID</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider">Estado CFDI</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-center">Status</th>
                        <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wider text-center">Comprobantes</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm">
                    @foreach (var item in ElementosPaginados)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-4 py-3 font-bold text-slate-900">@item.Pago</td>
                            <td class="px-4 py-3 text-slate-600">@item.Serie@item.Folio</td>
                            <td class="px-4 py-3 text-slate-600">@(item.Fecha.HasValue ? item.Fecha.Value.ToString("dd/MM/yyyy") : "-")</td>
                            <td class="px-4 py-3 text-slate-600">@(item.FechaPago.HasValue ? item.FechaPago.Value.ToString("dd/MM/yyyy") : "-")</td>
                            <td class="px-4 py-3 font-medium text-slate-900">@item.NombreCliente</td>
                            <td class="px-4 py-3 text-right font-bold text-green-600">@item.Abono?.ToString("C")</td>
                            <td class="px-4 py-3 text-slate-600">@item.NombreFormaPago</td>
                            <td class="px-4 py-3 font-mono text-xs text-slate-500">@item.Uuid</td>
                            <td class="px-4 py-3 text-slate-600">@item.Estado</td>
                            <td class="px-4 py-3 text-center">
                                <span class="px-2 py-1 text-xs font-bold rounded-md uppercase @(item.Status == "ACTIVO" ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-700")">
                                    @item.Status
                                </span>
                            </td>
                            <td class="px-4 py-3 text-center">
                                <div class="flex justify-center gap-2">
                                    <button @onclick="() => AbrirDetalles(item.Pago ?? string.Empty)"
                                            class="px-2 py-1.5 bg-amber-50 text-amber-600 hover:bg-amber-600 hover:text-white rounded-md transition-colors flex items-center gap-1 text-xs font-bold"
                                            title="Ver Detalles">
                                        <span class="material-symbols-outlined text-[16px]">visibility</span>
                                    </button>
                                    <button class="px-3 py-1.5 bg-red-50 text-red-600 hover:bg-red-600 hover:text-white rounded-md transition-colors flex items-center gap-1 text-xs font-bold"
                                            @onclick='() => DescargarPDF(item.Pago ?? string.Empty)' title="Descargar PDF">
                                        <span class="material-symbols-outlined text-[16px]">picture_as_pdf</span> PDF
                                    </button>
                                    <button class="px-3 py-1.5 bg-blue-50 text-blue-600 hover:bg-blue-600 hover:text-white rounded-md transition-colors flex items-center gap-1 text-xs font-bold"
                                            @onclick='() => DescargarXML("Pago", item.Uuid ?? string.Empty)' title="Descargar XML">
                                        <span class="material-symbols-outlined text-[16px]">code</span> XML
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <!-- TABLAS FINAL -->

    <!-- PAGINACION INICIO -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-4 bg-white border border-slate-200 p-4 rounded-2xl shadow-sm">
        <div class="text-sm text-slate-500">
            Mostrando <span class="font-bold text-slate-900">@(TotalRegistros == 0 ? 0 : ((PaginaActual - 1) * RegistrosPorPagina) + 1)</span> a
            <span class="font-bold text-slate-900">@(Math.Min(PaginaActual * RegistrosPorPagina, TotalRegistros))</span> de
            <span class="font-bold text-slate-900">@TotalRegistros</span> registros
        </div>

        <div class="flex border border-slate-200 rounded-lg overflow-hidden shadow-sm">
            <button class="px-3 py-1.5 bg-white text-slate-600 hover:bg-slate-50 transition-colors disabled:opacity-50 disabled:bg-slate-100 text-sm font-medium border-r border-slate-200"
                    @onclick="() => CambiarPagina(PaginaActual - 1)" disabled="@(PaginaActual == 1)">
                Anterior
            </button>

            @{
                int maxBotones = 10;
                int inicio = PaginaActual;
                int fin = Math.Min(TotalPaginas, inicio + maxBotones - 1);
                if (fin - inicio + 1 < maxBotones)
                {
                    inicio = Math.Max(1, fin - maxBotones + 1);
                }
            }

            @for (int i = inicio; i <= fin; i++)
            {
                int pag = i;
                <button class="px-4 py-1.5 text-sm font-bold border-r border-slate-200 last:border-r-0 transition-colors @(PaginaActual == pag ? "bg-blue-600 text-white" : "bg-white text-slate-600 hover:bg-slate-50")"
                        @onclick="() => CambiarPagina(pag)">
                    @pag
                </button>
            }

            <button class="px-3 py-1.5 bg-white text-slate-600 hover:bg-slate-50 transition-colors disabled:opacity-50 disabled:bg-slate-100 text-sm font-medium border-l border-slate-200"
                    @onclick="() => CambiarPagina(PaginaActual + 1)" disabled="@(PaginaActual == TotalPaginas || TotalPaginas == 0)">
                Siguiente
            </button>
        </div>
    </div>

    <ModalDetallePago Mostrar="@mostrarModalDetalles" 
                        PagoId="@pagoSeleccionadoId" 
                        OnCerrar="CerrarModal" />
}
<!-- PAGINACION FINAL -->


@inject NavigationManager NavManager

@code {
    [Parameter]
    public List<VwResumenComplementosPago>? complementoPagoList { get; set; }
    [Parameter]
    public bool EsAdmin { get; set; }

    [Parameter]
    public string RfcActual { get; set; } = "";

    [Parameter] 
    public int AnioActual { get; set; }

    [Parameter] 
    public EventCallback<int> OnAnioChanged { get; set; }

    //Variables de filtrado
    private string filtroRfc = "";
    private int? filtroCliente;
    private DateTime? filtroFechaInicio;
    private DateTime? filtroFechaFin;
    private string filtroUUID = "";

    private string _draftRfcFiltro = "";
    private int? draftCliente;
    private DateTime? draftFechaInicio;
    private DateTime? draftFechaFin;
    private string draftUUID = "";
    private int draftAnio;

    private bool mostrarModalDetalles = false;
    private string? pagoSeleccionadoId;

    private bool busquedaRealizada = false;
    private List<(int Numero, string Nombre)> ClientesDisponibles = new();

    private string DraftRfcFiltro
    {
        get => _draftRfcFiltro;
        set
        {
            _draftRfcFiltro = value;
            ActualizarDropdownClientes();
        }
    }

    // --- MOTOR DE FILTRADO ---
    private IEnumerable<VwResumenComplementosPago> ElementosFiltrados
    {
        get
        {
            if (!busquedaRealizada || complementoPagoList == null) return Enumerable.Empty<VwResumenComplementosPago>();

            var query = complementoPagoList.AsEnumerable();

            if (!string.IsNullOrWhiteSpace(filtroRfc))
            {
                query = query.Where(x => !string.IsNullOrEmpty(x.Rfc) &&
                                         x.Rfc.Contains(filtroRfc, StringComparison.OrdinalIgnoreCase));
            }

            if (filtroCliente.HasValue)
                query = query.Where(x => x.Cliente == filtroCliente.Value);

            if (filtroFechaInicio.HasValue)
                query = query.Where(x => x.FechaPago.HasValue && x.FechaPago.Value.Date >= filtroFechaInicio.Value.Date);

            if (filtroFechaFin.HasValue)
                query = query.Where(x => x.FechaPago.HasValue && x.FechaPago.Value.Date <= filtroFechaFin.Value.Date);

            if (!string.IsNullOrWhiteSpace(filtroUUID))
                query = query.Where(x => !string.IsNullOrEmpty(x.Uuid) &&
                                         x.Uuid.Contains(filtroUUID, StringComparison.OrdinalIgnoreCase));

            return query;
        }
    }

    // --- PAGINACIÓN ---
    private int paginaActual = 1;
    private int registrosPorPagina = 10;

    private int RegistrosPorPagina
    {
        get => registrosPorPagina;
        set { registrosPorPagina = value; paginaActual = 1; }
    }

    private int PaginaActual => paginaActual;
    private int TotalRegistros => ElementosFiltrados.Count();
    private int TotalPaginas => TotalRegistros == 0 ? 1 : (int)Math.Ceiling((double)TotalRegistros / RegistrosPorPagina);

    private IEnumerable<VwResumenComplementosPago> ElementosPaginados =>
        ElementosFiltrados.Skip((paginaActual - 1) * RegistrosPorPagina).Take(RegistrosPorPagina);

    protected override void OnInitialized()
    {
        // Aplicamos el filtro si es un cliente normal
        if (!EsAdmin)
        {
            _draftRfcFiltro = RfcActual;
            filtroRfc = RfcActual;
            draftAnio = AnioActual;
        }
    }

    protected override void OnParametersSet()
    {
        ActualizarDropdownClientes();
    }

    private async Task AplicarFiltros()
    {
        if (draftAnio != AnioActual)
        {
            await OnAnioChanged.InvokeAsync(draftAnio);
        }
        filtroRfc = _draftRfcFiltro;
        filtroCliente = draftCliente;
        filtroFechaInicio = draftFechaInicio;
        filtroFechaFin = draftFechaFin;
        filtroUUID = draftUUID;

        busquedaRealizada = true;
        paginaActual = 1;
    }

    private void LimpiarFiltros()
    {
        if (EsAdmin)
        {
            _draftRfcFiltro = "";
        }
        draftFechaInicio = null;
        draftFechaFin = null;
        draftUUID = "";
        if (ClientesDisponibles.Count > 1)
        {
            draftCliente = null;
        }

        busquedaRealizada = false;
        draftAnio = AnioActual;
    }

    private void CambiarPagina(int nuevaPagina)
    {
        if (nuevaPagina >= 1 && nuevaPagina <= TotalPaginas)
        {
            paginaActual = nuevaPagina;
        }
    }

    private void ActualizarDropdownClientes()
    {
        if (complementoPagoList == null || !complementoPagoList.Any()) return;

        var query = complementoPagoList.AsEnumerable();

        // Si es admin y escribió algo en el RFC, filtramos los clientes de ese RFC
        if (EsAdmin && !string.IsNullOrWhiteSpace(_draftRfcFiltro))
        {
            query = query.Where(x => !string.IsNullOrEmpty(x.Rfc) &&
                                     x.Rfc.Contains(_draftRfcFiltro, StringComparison.OrdinalIgnoreCase));
        }

        // Construimos la lista ordenada alfabéticamente
        ClientesDisponibles = query
            .Where(f => f.Cliente.HasValue)
            .GroupBy(f => f.Cliente.Value)
            .Select(grupo => (Numero: grupo.Key, Nombre: grupo.First().NombreCliente ?? "Sin Nombre"))
            .OrderBy(c => c.Nombre)
            .ToList();

        // Si el cliente que estaba seleccionado ya no está en la nueva lista, lo limpiamos
        if (draftCliente.HasValue && !ClientesDisponibles.Any(c => c.Numero == draftCliente.Value))
        {
            draftCliente = null;
        }

        // Si la búsqueda solo dejó 1 cliente disponible, lo auto-seleccionamos
        if (ClientesDisponibles.Count == 1)
        {
            draftCliente = ClientesDisponibles.First().Numero;
        }
    }

    //Metodo para descargar PDF
    public void DescargarPDF(string folio)
    {
        NavManager.NavigateTo($"/api/pdf/pago/{folio}", forceLoad: true);
    }

    private void DescargarXML(string tipo, string uuid)
    {
        string urlApi = $"/api/descargar/xml/{tipo}/{uuid}";
        NavManager.NavigateTo(urlApi, forceLoad: true);
    }

    private void AbrirDetalles(string id)
    {
        pagoSeleccionadoId = id;
        mostrarModalDetalles = true;
    }

    private void CerrarModal()
    {
        mostrarModalDetalles = false;
    }
}