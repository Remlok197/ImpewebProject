        </Authorized>
    </AuthorizeView>

    <AuthorizeView Roles="Administrador">
    <Authorized>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="admin/crear-usuario">
                <span class="bi bi-person-plus-fill" aria-hidden="true"></span> Registrar Usuario
            </NavLink>
        </div>
    </Authorized>
</AuthorizeView>
