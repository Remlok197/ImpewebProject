@page "/pedidos"
@attribute [Authorize]
@rendermode InteractiveServer
@using ImpewebProject.Models
@using ImpewebProject.Services
@using ImpewebProject.Components.Tables
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IPedidosService PedidosService
@inject IAuditoriaService AuditoriaService

@if (pedidosList == null)
{
    <p><em>Cargando datos...</em></p>
}
else
{
    <TablePedido pedidosList="pedidosList"
                 EsAdmin="EsAdmin"
                 RfcActual="@RfcActual"
                 AnioActual="anioSeleccionado"
                 OnAnioChanged="CargarPedidosPorAnio" />
}

@code {
    private List<VwResumenPedido>? pedidosList;
    private bool EsAdmin = false;
    private string RfcActual = "";

    private int anioSeleccionado = DateTime.Now.Year;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            RfcActual = user.Identity.Name ?? "";
            EsAdmin = user.IsInRole("Administrador");
        }

        pedidosList = await PedidosService.ObtenerPedidosPorRfcAsync(anioSeleccionado, RfcActual, EsAdmin);

        string rolUsuario = EsAdmin ? "Administrador" : "Cliente";
        await AuditoriaService.RegistrarAccionAsync(RfcActual, $"Consultó el módulo de Pedidos como {rolUsuario}");
    }

    private async Task CargarPedidosPorAnio(int nuevoAnio)
    {
        anioSeleccionado = nuevoAnio;
        pedidosList = await PedidosService.ObtenerPedidosPorRfcAsync(anioSeleccionado, RfcActual, EsAdmin);
    }
}