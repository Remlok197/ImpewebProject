@page "/admin/crear-usuario"
@attribute [Authorize(Roles = "Administrador")]
@using System.ComponentModel.DataAnnotations
@using ImpewebProject.Data
@using ImpewebProject.Models
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<ImpewebContext> DbFactory
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthStateProvider

<div class="min-h-screen bg-[#0F172A] flex items-center justify-center p-6">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-2xl overflow-hidden">
        <div class="p-8 sm:p-12 pb-8">

            <div class="flex flex-col items-center mb-8">
                <img src="/Impeweb Logo.jpg" alt="Impeweb Logo" style="max-height: 80px;" />
                <h2 class="text-2xl font-bold text-slate-900">Creación de Usuarios</h2>
                <p class="text-slate-500 text-center mt-2 text-sm">Alta de nuevos clientes al Portal Fiscal.</p>
            </div>

            @if (MostrarError)
            {
                <div class="bg-red-50 border-l-4 border-red-500 text-red-700 p-4 rounded-lg mb-6 flex items-center gap-3 animate-pulse">
                    <span class="material-symbols-outlined">error</span>
                    <p class="text-sm font-medium">@MensajeError</p>
                </div>
            }

            @if (MostrarExito)
            {
                <div class="bg-green-50 border-l-4 border-green-500 text-green-700 p-4 rounded-lg mb-6 flex items-center gap-3 animate-fade-in-down">
                    <span class="material-symbols-outlined">check_circle</span>
                    <p class="text-sm font-medium">¡Cliente creado exitosamente!</p>
                </div>
            }

            <EditForm Model="registroModel" OnValidSubmit="ProcesarRegistro" class="space-y-5">
                <DataAnnotationsValidator />

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">RFC del Cliente</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">domain</span>
                        <InputText @bind-Value="registroModel.RFC" placeholder="Ej. ISO150212C50" style="text-transform: uppercase;"
                                   class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" />
                    </div>
                    <ValidationMessage For="@(() => registroModel.RFC)" class="text-red-500 text-xs mt-1 font-medium" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Contraseña</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
                        <input type="password" placeholder="••••••••"
                               @bind="registroModel.Password" @bind:event="oninput"
                               class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" />
                    </div>

                    <div class="mt-3 grid grid-cols-1 gap-1.5 text-xs font-medium bg-slate-50 p-3 rounded-lg border border-slate-100">
                        <div class="flex items-center gap-2 @ObtenerColor(TieneMasDe8) transition-colors">
                            <span class="material-symbols-outlined text-[16px]">@ObtenerIcono(TieneMasDe8)</span> Más de 8 caracteres
                        </div>
                        <div class="flex items-center gap-2 @ObtenerColor(TieneMayuscula) transition-colors">
                            <span class="material-symbols-outlined text-[16px]">@ObtenerIcono(TieneMayuscula)</span> Al menos una mayúscula
                        </div>
                        <div class="flex items-center gap-2 @ObtenerColor(TieneMinuscula) transition-colors">
                            <span class="material-symbols-outlined text-[16px]">@ObtenerIcono(TieneMinuscula)</span> Al menos una minúscula
                        </div>
                        <div class="flex items-center gap-2 @ObtenerColor(TieneNumero) transition-colors">
                            <span class="material-symbols-outlined text-[16px]">@ObtenerIcono(TieneNumero)</span> Al menos un número
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-2">Confirmar Contraseña</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">password</span>
                        <InputText type="password" @bind-Value="registroModel.ConfirmarPassword" placeholder="••••••••"
                                   class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all" />
                    </div>
                    <ValidationMessage For="@(() => registroModel.ConfirmarPassword)" class="text-red-500 text-xs mt-1 font-medium" />
                </div>

                <button type="submit" disabled="@(Cargando || !CumpleTodosLosCriterios)" class="w-full py-4 mt-2 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl shadow-lg shadow-blue-600/30 flex items-center justify-center gap-2 transition-all active:scale-[0.98] disabled:opacity-50 disabled:cursor-not-allowed">
                    @(Cargando ? "Registrando..." : "Crear Cliente")
                    @if (Cargando)
                    {
                        <span class="material-symbols-outlined animate-spin">progress_activity</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined">how_to_reg</span>
                    }
                </button>
            </EditForm>
        </div>

        <div class="p-6 bg-slate-50 border-t border-slate-100 flex flex-col items-center gap-4">
            <div class="flex gap-6 text-slate-400">
                <div class="flex items-center gap-1 text-xs">
                    <span class="material-symbols-outlined text-sm">shield_lock</span>
                    Acceso Exclusivo Administración - BCrypt Secured
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private RegistroDTO registroModel = new RegistroDTO();
    private bool MostrarError = false;
    private string MensajeError = "";
    private bool MostrarExito = false;
    private bool Cargando = false;

    // --- LÓGICA DEL VALIDADOR VISUAL ---
    private string PassSeguro => registroModel.Password ?? "";

    private bool TieneMasDe8 => PassSeguro.Length > 8;
    private bool TieneMayuscula => PassSeguro.Any(char.IsUpper);
    private bool TieneMinuscula => PassSeguro.Any(char.IsLower);
    private bool TieneNumero => PassSeguro.Any(char.IsDigit);

    private bool CumpleTodosLosCriterios => TieneMasDe8 && TieneMayuscula && TieneMinuscula && TieneNumero;

    private string ObtenerColor(bool cumplido) => cumplido ? "text-green-600" : "text-slate-400";
    private string ObtenerIcono(bool cumplido) => cumplido ? "check_circle" : "radio_button_unchecked";

    private async Task ProcesarRegistro()
    {
        MostrarError = false;
        MostrarExito = false;
        Cargando = true;

        try
        {
            var rfcLimpio = registroModel.RFC?.Trim().ToUpper() ?? "";
            using var context = DbFactory.CreateDbContext();
            bool existe = context.UsuarioWeb.Any(u => u.RFC == rfcLimpio);
            if (existe)
            {
                MensajeError = "Este RFC ya se encuentra registrado en el sistema.";
                MostrarError = true;
                Cargando = false;
                return;
            }

            string hashSeguro = BCrypt.Net.BCrypt.HashPassword(registroModel.Password);

            var nuevoUsuario = new UsuarioWeb
            {
                RFC = rfcLimpio,
                PasswordHash = hashSeguro,
                Rol = "Cliente",
                Activo = true
            };

            context.UsuarioWeb.Add(nuevoUsuario);
            await context.SaveChangesAsync();

            MostrarExito = true;
            registroModel = new RegistroDTO();
            Cargando = false;
        }
        catch (Exception)
        {
            MensajeError = "Ocurrió un error en la base de datos al intentar registrar el usuario.";
            MostrarError = true;
            Cargando = false;
        }
    }
}