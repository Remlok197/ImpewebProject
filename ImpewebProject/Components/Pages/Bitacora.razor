@page "/auditoria"
@attribute [Authorize(Roles = "Administrador")] 
@using ImpewebProject.Models
@using ImpewebProject.Services
@using Microsoft.AspNetCore.Authorization
@inject IAuditoriaService AuditoriaService

<div class="container mt-4">
    @if (registros == null)
    {
        <div class="text-center mt-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Fecha y Hora</th>
                            <th>RFC Usuario</th>
                            <th>Acción Realizada</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in registros)
                        {
                            <tr>
                                <td class="text-muted" style="white-space: nowrap;">@log.FechaHora.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                <td class="fw-bold">@log.RFC</td>
                                <td>@log.Accion</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private List<BitacoraAuditoria>? registros;

    protected override async Task OnInitializedAsync()
    {
        registros = await AuditoriaService.ObtenerBitacoraAsync();
    }
}