@page "/facturas"
@attribute [Authorize]
@rendermode InteractiveServer
@using ImpewebProject.Services
@using ImpewebProject.Models
@using ImpewebProject.Components.Tables
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IFacturaService FacturaService
@inject IAuditoriaService AuditoriaService

<TableFacturas facturasList="facturasList" EsAdmin="EsAdmin" RfcActual="@RfcActual" AnioActual="yearSelected" OnAnioChanged="CargarFacturasPorAnio"/>


@code {
    private List<VwResumenFactura>? facturasList;

    private bool EsAdmin = false;
    private string RfcActual = "";
    private int yearSelected = DateTime.Now.Year;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            RfcActual = user.Identity.Name ?? "";
            EsAdmin = user.IsInRole("Administrador");
        }
   
        facturasList = await FacturaService.ObtenerFacturasAsync(2026, RfcActual, EsAdmin);

        string rolUsuario = EsAdmin ? "Administrador" : "Cliente";
        await AuditoriaService.RegistrarAccionAsync(RfcActual, $"Consultó el módulo de Facturas como {rolUsuario}");
    }

    private async Task CargarFacturasPorAnio(int newYear)
    {
        yearSelected = newYear;
        facturasList = await FacturaService.ObtenerFacturasAsync(yearSelected, RfcActual, EsAdmin);
    }
}